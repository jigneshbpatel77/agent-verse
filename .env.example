# Global Monorepo Environment Variables
SERVICE_NAME=monorepo-orchestration
ENVIRONMENT=development
PORT=8080

# Source of Truth - PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_verse

# Caching, Workflow Locking, and Session Memory - Redis
REDIS_URL=redis://localhost:6379

# Event Streaming Broker - Kafka
KAFKA_BROKERS=localhost:9092

# Vector DB Knowledge Memory - Qdrant
QDRANT_URL=http://localhost:6333

# Analytics & OLAP - ClickHouse
CLICKHOUSE_URL=clickhouse://localhost:8123

# Durable Workflow Orchestration - Temporal
TEMPORAL_ADDRESS=localhost:7233

# AI Models & LLM Routers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Observability, Traces, and Metrics - OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=orchestrator-gateway

# Security & Authentication
JWT_SECRET=super_secure_jwt_secret_change_in_production
