SERVICE_NAME=analytics-agent
ENVIRONMENT=local
PORT=8010
DATABASE_URL=postgresql://platform:platform@localhost:5432/agent_platform
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
QDRANT_URL=http://localhost:6333
CLICKHOUSE_URL=http://localhost:8123
TEMPORAL_ADDRESS=localhost:7233
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=OPENROUTER
PROVIDER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
COMMANDER_LLM_TIMEOUT_SECONDS=30
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
JWT_SECRET=change-me-in-production
PROMETHEUS_URL=http://localhost:9090
RC_SERVICE_NAME=rc-service
RC_PROVIDER_NAME=rc-provider
RC_ENVIRONMENT=staging
RC_HEALTH_CHECK_URL=https://vi-api.vehicleinfo.app/RC/rc_details_get_and_store/api/health_check
WEBHOOK_HEALTH_CHECK_URL=https://webhook.vehicleinfo.app/webhook/api/health_check
PROMETHEUS_QUERY_TIMEOUT_SECONDS=10
RC_SERVICE_LABEL=service
RC_PROVIDER_LABEL=provider
RC_STATUS_LABEL=status_code
RC_ENVIRONMENT_LABEL=
RC_POD_LABEL=pod
RC_POD_PATTERN=rc-service.*

# Monitoring alerting domain: CloudWatch log analysis.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
CLOUDWATCH_LOG_GROUPS=RC_fetching_prod
CLOUDWATCH_FILTER_PATTERN=
CLOUDWATCH_LOOKBACK_MINUTES=2
CLOUDWATCH_POLL_INTERVAL_SECONDS=60
ENABLE_CLOUDWATCH_POLLER=true

LLM_PROVIDER=grok
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4
MAX_LOG_CHARS=12000
ALERT_MIN_SEVERITY=medium
ALERT_WEBHOOK_URL=

# Firebase Analytics and Crashlytics dashboard integration.
# Use a Firebase/GCP service account JSON path here. Do not commit that JSON.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=plucky-lane-128505
FIREBASE_GA4_PROPERTY_ID=
FIREBASE_ANDROID_APP_ID=1:662436393520:android:a4d882ff823ae28d
FIREBASE_REQUEST_TIMEOUT_SECONDS=20

# VehicleInfo dashboard API (Google Ads campaign performance), cached into DuckDB.
VEHICLEINFO_DASHBOARD_BASE_URL=https://dashboard-prod-api.vehicleinfo.app
VEHICLEINFO_DASHBOARD_EMAIL=
VEHICLEINFO_DASHBOARD_PASSWORD=
VEHICLEINFO_DASHBOARD_API_KEY=
GOOGLE_ADS_REQUEST_TIMEOUT_SECONDS=20
GOOGLE_ADS_AUTH_TOKEN_TTL_SECONDS=3300
ENABLE_GOOGLE_ADS_SYNC=false

# Business analytics domain: RDS to DuckDB revenue warehouse.
ANALYTICS_DUCKDB_PATH=
ENABLE_BUSINESS_ANALYTICS_SYNC=false
BUSINESS_ANALYTICS_SYNC_INTERVAL_SECONDS=900
BUSINESS_ANALYTICS_LOCAL_FALLBACK_ONLY=false
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DATABASE=
RDS_SSL_MODE=
RDS_CHALLAN_HOST=
RDS_CHALLAN_PORT=
RDS_CHALLAN_USER=
RDS_CHALLAN_PASSWORD=
RDS_CHALLAN_DATABASE=
RDS_CHALLAN_TABLE=challan_payment
RDS_CHALLAN_SSL_MODE=
RDS_SERVICE_HISTORY_HOST=
RDS_SERVICE_HISTORY_PORT=
RDS_SERVICE_HISTORY_USER=
RDS_SERVICE_HISTORY_PASSWORD=
RDS_SERVICE_HISTORY_DATABASE=
RDS_SERVICE_HISTORY_TABLE=service_history_payments
RDS_SERVICE_HISTORY_SSL_MODE=

# User-registration analytics source (config-driven; flip csv<->rds with no code change).
# The RDS path reuses the RDS_SERVICE_HISTORY_* connection (RC read-replica, RTO_SUMIT).
# Default is live RDS; set to 'csv' (with a path below) to fall back to a file export.
USER_REGISTRATION_DATA_SOURCE=rds
USER_REGISTRATION_CSV_PATH=
USER_REGISTRATION_RDS_TABLE=user_registration
USER_REGISTRATION_FETCH_LIMIT=1000
# Warehouse retention window in days. 0 = keep every fetched row (no date cap).
USER_REGISTRATION_RETENTION_DAYS=3
USER_REGISTRATION_RDS_MAX_RETRIES=3
USER_REGISTRATION_RDS_RETRY_BACKOFF_SECONDS=2.0
RDS_FASTAG_HOST=
RDS_FASTAG_PORT=
RDS_FASTAG_USER=
RDS_FASTAG_PASSWORD=
RDS_FASTAG_DATABASE=
RDS_FASTAG_TABLE=buy_fastag_payment
RDS_FASTAG_SSL_MODE=

# Policybazaar Gmail ingestion.
ENABLE_POLICYBAZAAR_EMAIL_INGESTION=false
GMAIL_DELEGATED_USER=
# Optional for Workspace/domain-wide delegation. If omitted, the app uses Google Application Default Credentials.
GMAIL_SERVICE_ACCOUNT_FILE=
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_PUBSUB_TOPIC=projects/<gcp-project-id>/topics/<gmail-topic>
GMAIL_PUBSUB_VERIFICATION_TOKEN=
GMAIL_WATCH_LABEL_IDS=INBOX
GMAIL_POLICYBAZAAR_SENDER=analytic@policybazaar.com
GMAIL_POLICYBAZAAR_SUBJECT_KEYWORD=VehicleInfo Two-wheeler MTD booking till
GMAIL_POLICYBAZAAR_CAR_SUBJECT_KEYWORD=Vehicleinfo_Motor
GMAIL_POLICYBAZAAR_CV_SUBJECT_KEYWORD=Vehicleinfo_Cv
POLICYBAZAAR_REFRESH_WINDOW_DAYS=15
